<Window
    x:Class="D2RPriceChecker.UI.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:D2RPriceChecker.UI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SettingsWindow"
    Width="600"
    Height="400"
    mc:Ignorable="d">
    <Grid>
        <StackPanel Margin="10" Orientation="Vertical">
            <CheckBox Content="Automatically check for updates" IsChecked="{Binding AutoCheckForUpdates}" />
            <CheckBox Content="Save images to disk" IsChecked="{Binding SaveImagesToDisk}" />
        </StackPanel>


    </Grid>
</Window>
