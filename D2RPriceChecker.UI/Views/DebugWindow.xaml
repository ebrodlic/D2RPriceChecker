<Window
    x:Class="D2RPriceChecker.UI.Views.DebugWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:D2RPriceChecker.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DebugWindow"
    Width="1600"
    Height="800"
    WindowState="Maximized"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid x:Name="LayoutGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <!--  Left side: Image display and controls  -->
                <ColumnDefinition Width="2" />
                <!--  Separator: Vertical line  -->
                <ColumnDefinition Width="2*" />
                <!--  Right side: Text OCR and Debug log  -->
            </Grid.ColumnDefinitions>

            <!--  Left side: Image display and controls  -->
            <StackPanel Grid.Column="0" Margin="10">

                <!--  Label  -->
                <TextBlock
                    Margin="0,0,0,5"
                    FontWeight="Bold"
                    Text="Screenshot" />

                <!--  Controls: Image path, Browse button, Navigation buttons, Process button, Auto-process checkbox  -->
                <StackPanel
                    Height="24"
                    Margin="0,0,0,10"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Text="Image Path:" />
                    <TextBox
                        Name="ImagePathTextBox"
                        Width="600"
                        Margin="0,0,5,0"
                        VerticalContentAlignment="Center" />
                    <Button
                        Width="80"
                        Margin="0,0,5,0"
                        Click="BrowseImages_Click"
                        Content="Browse" />
                    <Button
                        Width="30"
                        Margin="0,0,5,0"
                        Click="LeftButton_Click"
                        Content="←" />
                    <Button
                        Width="30"
                        Margin="0,0,5,0"
                        Click="RightButton_Click"
                        Content="→" />
                    <Button
                        Width="80"
                        Margin="0,0,5,0"
                        Click="ProcessButton_Click"
                        Content="Process" />
                    <CheckBox
                        x:Name="AutoProcessCheckBox"
                        Margin="5,0,0,0"
                        VerticalAlignment="Center"
                        Content="Auto-process"
                        IsChecked="True" />
                    <Image
                        x:Name="LoadingSpinner"
                        Width="32"
                        Height="32"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="Collapsed" />
                </StackPanel>

                <!--  2x2 grid for pipeline stage images  -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Top Left  -->
                    <Border
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="5"
                        BorderBrush="Gray"
                        BorderThickness="1">
                        <ScrollViewer
                            PreviewMouseLeftButtonDown="Scroll_MouseDown"
                            PreviewMouseLeftButtonUp="Scroll_MouseUp"
                            PreviewMouseMove="Scroll_MouseMove"
                            Style="{StaticResource StageScrollViewerStyle}">
                            <Image
                                x:Name="Stage1Image"
                                MouseRightButtonDown="Image_MouseRightButtonDown"
                                Stretch="None" />
                        </ScrollViewer>
                    </Border>
                    <!--  Top Right  -->
                    <Border
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="5"
                        BorderBrush="Gray"
                        BorderThickness="1">
                        <ScrollViewer
                            PreviewMouseLeftButtonDown="Scroll_MouseDown"
                            PreviewMouseLeftButtonUp="Scroll_MouseUp"
                            PreviewMouseMove="Scroll_MouseMove"
                            Style="{StaticResource StageScrollViewerStyle}">
                            <Image
                                x:Name="Stage2Image"
                                MouseRightButtonDown="Image_MouseRightButtonDown"
                                Stretch="None" />
                        </ScrollViewer>
                    </Border>
                    <!--  Bottom Left  -->
                    <Border
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="5"
                        BorderBrush="Gray"
                        BorderThickness="1">
                        <ScrollViewer
                            PreviewMouseLeftButtonDown="Scroll_MouseDown"
                            PreviewMouseLeftButtonUp="Scroll_MouseUp"
                            PreviewMouseMove="Scroll_MouseMove"
                            Style="{StaticResource StageScrollViewerStyle}">
                            <Image
                                x:Name="Stage3Image"
                                MouseRightButtonDown="Image_MouseRightButtonDown"
                                Stretch="None" />
                        </ScrollViewer>
                    </Border>
                    <!--  Bottom Right  -->
                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="5"
                        BorderBrush="Gray"
                        BorderThickness="1">
                        <ScrollViewer
                            PreviewMouseLeftButtonDown="Scroll_MouseDown"
                            PreviewMouseLeftButtonUp="Scroll_MouseUp"
                            PreviewMouseMove="Scroll_MouseMove"
                            Style="{StaticResource StageScrollViewerStyle}">
                            <Image
                                x:Name="Stage4Image"
                                MouseRightButtonDown="Image_MouseRightButtonDown"
                                Stretch="None" />
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!--  Tooltip image and lines section  -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <!--  Tooltip  -->
                        <ColumnDefinition Width="5" />
                        <!--  Separator  -->
                        <ColumnDefinition Width="1*" />
                        <!--  Lines  -->
                    </Grid.ColumnDefinitions>

                    <!--  Left side: Tooltip image  -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">
                        <TextBlock
                            Margin="0,0,0,5"
                            FontWeight="Bold"
                            Text="Tooltip" />

                        <ScrollViewer
                            PreviewMouseLeftButtonDown="Scroll_MouseDown"
                            PreviewMouseLeftButtonUp="Scroll_MouseUp"
                            PreviewMouseMove="Scroll_MouseMove"
                            Style="{StaticResource TooltipScrollViewerStyle}">
                            <Image Name="TooltipImageControl" Stretch="None" />
                        </ScrollViewer>
                    </StackPanel>

                    <!--  Separator: Vertical line  -->
                    <Border
                        Grid.Column="1"
                        Width="1"
                        HorizontalAlignment="Center"
                        Background="Gray" />

                    <!--  Right side: Lines section  -->
                    <StackPanel Grid.Column="2" Orientation="Vertical">
                        <TextBlock
                            Margin="0,0,0,5"
                            FontWeight="Bold"
                            Text="Lines" />
                        <ScrollViewer
                            PreviewMouseLeftButtonDown="Scroll_MouseDown"
                            PreviewMouseLeftButtonUp="Scroll_MouseUp"
                            PreviewMouseMove="Scroll_MouseMove"
                            Style="{StaticResource TooltipScrollViewerStyle}">
                            <StackPanel Name="LinesStackPanel" Orientation="Vertical" />
                        </ScrollViewer>


                    </StackPanel>

                </Grid>

            </StackPanel>

            <!--  Separator: Vertical line  -->
            <Border
                Grid.Column="1"
                Width="1"
                HorizontalAlignment="Center"
                Background="Gray" />

            <!--  Right side: Text OCR and Debug log  -->
            <Grid Grid.Column="2" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*" />
                    <!--  Settings  -->
                    <RowDefinition Height="5" />
                    <!--  Separator  -->
                    <RowDefinition Height="1*" />
                    <!--  Metadata  -->
                    <RowDefinition Height="5" />
                    <!--  Separator  -->
                    <RowDefinition Height="1*" />
                    <!--  OCR  -->
                    <RowDefinition Height="5" />
                    <!--  Separator  -->
                    <RowDefinition Height="1*" />
                    <!--  Debug  -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="Bold"
                        Text="Settings" />
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="15" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Row 0  -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Content Cutoff Value:" />
                        <TextBox
                            x:Name="ContentCutoffValueTextBox"
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="5" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="3"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Distance Threshold:" />
                        <TextBox
                            x:Name="DistanceThresholdTextBox"
                            Grid.Row="0"
                            Grid.Column="4"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="40" />

                        <!--  Row 1  -->
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Max Rows Blob Sequence Length:" />
                        <TextBox
                            x:Name="MaxRowsBlobSequenceLengthTextBox"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="11" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="3"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Placeholder Prop:" />
                        <TextBox
                            x:Name="PlaceholderPropTextBox"
                            Grid.Row="1"
                            Grid.Column="4"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="10" />

                        <!--  Row 2  -->
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Brightness Threshold:" />
                        <TextBox
                            x:Name="BrightnessThresholdTextBox"
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="80" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="3"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Max Channel Threshold:" />
                        <TextBox
                            x:Name="MaxChannelThresholdTextBox"
                            Grid.Row="2"
                            Grid.Column="4"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="140" />

                        <!--  Row 3  -->
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Capitalization Offset:" />
                        <TextBox
                            x:Name="CapitalizationOffsetTextBox"
                            Grid.Row="3"
                            Grid.Column="1"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="6" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="3"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Floor Offset:" />
                        <TextBox
                            x:Name="FloorOffsetTextBox"
                            Grid.Row="3"
                            Grid.Column="4"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="3" />

                        <!--  Row 4  -->
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="0"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Padding Top:" />
                        <TextBox
                            x:Name="PaddingTopTextBox"
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="5" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="3"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Padding Bottom:" />
                        <TextBox
                            x:Name="PaddingBottomTextBox"
                            Grid.Row="4"
                            Grid.Column="4"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="3" />

                        <!--  Row 5  -->
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="0"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Padding Left:" />
                        <TextBox
                            x:Name="PaddingLeftTextBox"
                            Grid.Row="5"
                            Grid.Column="1"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="24" />
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="3"
                            Margin="0,0,5,5"
                            VerticalAlignment="Center"
                            Text="Padding Right:" />
                        <TextBox
                            x:Name="PaddingRightTextBox"
                            Grid.Row="5"
                            Grid.Column="4"
                            Margin="0,0,0,5"
                            VerticalContentAlignment="Center"
                            Text="24" />
                    </Grid>
                </StackPanel>

                <!--  Separator  -->
                <Border
                    Grid.Row="1"
                    Height="1"
                    VerticalAlignment="Center"
                    Background="Gray" />

                <!--  Tooltip image  -->
                <StackPanel Grid.Row="2">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="Bold"
                        Text="Metadata" />
                    <TextBox
                        Name="MetadataTextBox"
                        Height="200"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />

                </StackPanel>

                <!--  Separator  -->
                <Border
                    Grid.Row="3"
                    Height="1"
                    VerticalAlignment="Center"
                    Background="Gray" />

                <!--  Tooltip image  -->
                <StackPanel Grid.Row="4">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="Bold"
                        Text="OCR Result" />
                    <TextBox
                        Name="OcrResultTextBox"
                        Height="200"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />

                    <!--</Border>-->
                </StackPanel>

                <!--  Separator  -->
                <Border
                    Grid.Row="5"
                    Height="1"
                    VerticalAlignment="Center"
                    Background="Gray" />

                <!--  Debug Log result  -->
                <StackPanel Grid.Row="6" Margin="0,10,0,0">
                    <TextBlock
                        Margin="0,0,0,5"
                        FontWeight="Bold"
                        Text="Debug Log" />
                    <TextBox
                        Name="DebugLogTextBox"
                        Height="200"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                </StackPanel>

            </Grid>
        </Grid>

        <!--  🔥 OVERLAY GOES HERE (LAST)  -->
        <Grid
            x:Name="Overlay"
            Panel.ZIndex="999"
            Background="#CC000000"
            MouseRightButtonDown="Overlay_Close"
            Visibility="Collapsed">

            <Image
                x:Name="OverlayImage"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Stretch="Uniform" />
        </Grid>
    </Grid>
</Window>
