<Window x:Class="D2RPriceChecker.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D2RPriceChecker.Windows"
        mc:Ignorable="d"
        Title="OverlayWindow"
        Height="600" Width="800" WindowStyle="None" AllowsTransparency="True" Background="Transparent" 
        Topmost="True" WindowState= "Maximized" ShowInTaskbar="False" ResizeMode="NoResize">
    <Grid x:Name="Root" Background="#80000000">
        <!-- Click outside handler -->
        <Grid.InputBindings>
            <!-- optional -->
        </Grid.InputBindings>

        <!-- Centered content -->
        <Border
            x:Name="ContentPanel"
            Width="500"
            Padding="20"
            Background="#131415"
            CornerRadius="8"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MouseDown="ContentPanel_MouseDown">

            <DockPanel>
                <!-- Top: OCR text -->
                <ItemsControl ItemsSource="{Binding OcrLines}" DockPanel.Dock="Top">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="White" FontSize="12" Margin="0,0,0,2"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator DockPanel.Dock="Top" Margin="0,5" />

                <StackPanel Orientation="Vertical" DockPanel.Dock="Top" Margin="0,0,0,5">
                    <TextBlock Text="Min Price" Foreground="LightGreen" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Max Price" Foreground="LightGreen" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Estimate Price" Foreground="LightGreen" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="HR Value" Foreground="LightGreen" FontSize="16" FontWeight="Bold"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Margin="0,5" />

                <!-- Bottom: Trades -->
                <ScrollViewer x:Name="TradesScrollViewer" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
                    <ItemsControl ItemsSource="{Binding Trades}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderThickness="1" BorderBrush="Gray" Margin="0,2" Padding="4">
                                    <StackPanel Background="#202224">
                                        <TextBlock Text="Trade:" FontWeight="Bold" Foreground="White"/>
                                        <ItemsControl ItemsSource="{Binding Prices}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Quantity}" Foreground="White" Width="30"/>
                                                        <TextBlock Text="x " Foreground="White"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="White"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!--<StackPanel>
                <TextBlock x:Name="OcrText" Text="Your Item Details go Here" Foreground="White" TextWrapping="Wrap" Margin="10"/>
                <TextBlock x:Name="PriceText" Text="Price: 0" Foreground="LightGreen" FontSize="16" FontWeight="Bold" Margin="10"/>       
            </StackPanel>-->

        </Border>

    </Grid>
</Window>
