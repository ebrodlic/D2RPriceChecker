<Window x:Class="D2RPriceChecker.Windows.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D2RPriceChecker.Windows"
        mc:Ignorable="d"
        Title="D2R Price Checker" 
        Height="400" Width="320"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown" Background="Transparent">

        <Button Content="_" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,35,0" Width="24" Height="24"
            Background="Transparent" BorderThickness="0" FontWeight="Bold" FontSize="14" Cursor="Hand"
            Click="MinimizeButton_Click"/>
        <Button Content="X" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,5,0" Width="24" Height="24" 
                Background="Transparent" BorderThickness="0" FontWeight="Bold" FontSize="14" Cursor="Hand"
                Click="CloseButton_Click"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="D2R Price Checker" FontSize="18" FontWeight="Bold" TextAlignment="Center"/>
            <TextBlock Text="v1.0.0" FontSize="12" TextAlignment="Center" Margin="0,5,0,0"/>
            <TextBlock Text="Press Ctrl+D to check price" FontSize="14" TextAlignment="Center" Margin="0,25,0,0"/>
        </StackPanel>
    </Grid>
</Window>
