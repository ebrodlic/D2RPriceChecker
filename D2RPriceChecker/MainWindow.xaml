<Window x:Class="D2RPriceChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D2RPriceChecker"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="1600">    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" />    <!-- 60% -->
            <ColumnDefinition Width="5" />     <!-- Separator -->
            <ColumnDefinition Width="3*" />    <!-- 40% -->
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">


            <!-- Label -->
            <TextBlock Text="Screenshot" FontWeight="Bold" Margin="0,0,0,5"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Image Path:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Name="ImagePathTextBox" Width="650" Margin="0,0,5,0"/>
                <Button Content="Browse" Click="BrowseImages_Click" Width="80" Margin="0,0,5,0"/>
                <Button Content="←" Click="LeftButton_Click" Width="30" Margin="0,0,5,0"/>
                <Button Content="→" Click="RightButton_Click" Width="30" Margin="0,0,5,0"/>
                <Button Content="Process" Click="ProcessButton_Click" Width="80" Margin="0,0,5,0"/>
            </StackPanel>



            <!-- Screenshot image -->
            <Border BorderBrush="Gray" BorderThickness="1">
                <ScrollViewer>
                    <Image Name="ScreenshotImageControl" Stretch="Uniform"/>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <!-- Separator -->
        <Border Grid.Column="1"
            Background="Gray"
            Width="1"
            HorizontalAlignment="Center" />

        <Grid Grid.Column="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" /> <!-- Tooltip -->
                <RowDefinition Height="5" />  <!-- Separator -->
                <RowDefinition Height="1*" /> <!-- OCR -->
            </Grid.RowDefinitions>

            <!-- Tooltip image -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Tooltip" FontWeight="Bold" Margin="0,0,0,5"/>
                <!--<Border BorderBrush="Gray" BorderThickness="1">-->
                    <Image Name="TooltipImageControl" Stretch="None"/>
                <!--</Border>-->
            </StackPanel>

            <!-- Separator -->
            <Border Grid.Row="1"
                Background="Gray"
                Height="1"
                VerticalAlignment="Center" />

            <!-- OCR result -->
            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <TextBlock Text="OCR Result" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Name="OcrResultTextBox"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Height="300"
                     IsReadOnly="True"/>
            </StackPanel>

        </Grid>


    </Grid>
</Window>
